#practical_04

#include <iostream>
using namespace std;

int x[10]; // stores solution

void solve(int n, int C, int index) {
    // If we reached last variable
    if(index == n - 1) {
        x[index] = C;

        // Print solution
        for(int i = 0; i < n; i++)
            cout << x[i] << " ";
        cout << endl;
        return;
    }

    // Try all values from 0 to C
    for(int i = 0; i <= C; i++) {
        x[index] = i;
        solve(n, C - i, index + 1);
    }
}

int main() {
    int n, C;

    cout << "Enter value of n: ";
    cin >> n;

    cout << "Enter value of C (<=10): ";
    cin >> C;

    cout << "\nSolutions:\n";
    solve(n, C, 0);

    return 0;
}
